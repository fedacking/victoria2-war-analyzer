{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Victoria 2 War Analyzer",
  "version": "0.1.0",
  "identifier": "com.fedacking.victoria2waranalyzer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Victoria 2 War Analyzer",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

